# Lichen validator testnet environment example.
# Mirrors /etc/lichen/env-testnet as generated by deploy/setup.sh.
# Install filled production files as root-owned 0600 files. Do not commit filled
# copies or live secrets.

LICHEN_NETWORK=testnet
LICHEN_RPC_PORT=8899
LICHEN_WS_PORT=8900
LICHEN_P2P_PORT=7001
LICHEN_EXTERNAL_ADDR=REPLACE_WITH_PUBLIC_HOSTNAME_OR_IP:7001
# Keep validator mesh connectivity explicit. Fill this with the other validator
# P2P endpoints on every validator host; never include the host's own endpoint.
# LICHEN_P2P_RESERVED_PEERS=HOST_A:7001,HOST_B:7001,HOST_C:7001
LICHEN_KEYPAIR_PASSWORD=REPLACE_WITH_KEYPAIR_PASSWORD
LICHEN_SIGNER_BIND=127.0.0.1:9201
LICHEN_SIGNER_AUTH_TOKEN=REPLACE_WITH_64_HEX_SIGNER_TOKEN
LICHEN_CONTRACTS_DIR=/var/lib/lichen/contracts
RUST_LOG=info
LICHEN_INCIDENT_STATUS_FILE=/etc/lichen/incident-status-testnet.json
LICHEN_SIGNED_METADATA_MANIFEST_FILE=/etc/lichen/signed-metadata-manifest-testnet.json
LICHEN_SERVICE_FLEET_CONFIG_FILE=/etc/lichen/service-fleet-testnet.json
LICHEN_SERVICE_FLEET_UPSTREAM_RPC_URL=
LICHEN_SERVICE_FLEET_STATUS_FILE=/var/lib/lichen/service-fleet-status-testnet.json
LICHEN_CHECKPOINT_KEEP_COUNT=2
LICHEN_EXTRA_ARGS=--auto-update=off

# Required when this validator exposes public bridge intake through RPC.
CUSTODY_URL=http://127.0.0.1:9105
CUSTODY_API_AUTH_TOKEN=REPLACE_WITH_64_HEX_CUSTODY_API_TOKEN

# Oracle price-feed overrides for hosts that cannot reach the default upstream.
# LICHEN_ORACLE_WS_URL=wss://stream.binance.us:9443/ws/solusdt@aggTrade/ethusdt@aggTrade/bnbusdt@aggTrade/neousdt@aggTrade/gasusdt@aggTrade/btcusdt@aggTrade
# LICHEN_ORACLE_REST_URL=https://api.binance.us/api/v3/ticker/price?symbols=["SOLUSDT","ETHUSDT","BNBUSDT","NEOUSDT","GASUSDT","BTCUSDT"]
# LICHEN_DISABLE_ORACLE=1
