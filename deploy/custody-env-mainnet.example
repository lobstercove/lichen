# Lichen custody mainnet environment example.
# Mirrors /etc/lichen/custody-env-mainnet as generated by deploy/setup.sh.
# Install filled production files as root-owned 0600 files. Do not commit filled
# copies or live secrets.

CUSTODY_DB_PATH=/var/lib/lichen/custody-db-mainnet
CUSTODY_API_AUTH_TOKEN=REPLACE_WITH_64_HEX_CUSTODY_API_TOKEN
CUSTODY_MASTER_SEED_FILE=/etc/lichen/secrets/custody-master-seed-mainnet.txt
CUSTODY_DEPOSIT_MASTER_SEED_FILE=/etc/lichen/secrets/custody-deposit-seed-mainnet.txt
CUSTODY_LICHEN_RPC_URL=http://127.0.0.1:9899
CUSTODY_POLL_INTERVAL_SECS=15
CUSTODY_DEPOSIT_TTL_SECS=86400
CUSTODY_LISTEN_PORT=9106
CUSTODY_SIGNER_AUTH_TOKEN=REPLACE_WITH_64_HEX_SIGNER_TOKEN
LICHEN_KEYPAIR_PASSWORD=REPLACE_WITH_KEYPAIR_PASSWORD
LICHEN_INCIDENT_STATUS_FILE=/etc/lichen/incident-status-mainnet.json
RUST_LOG=info
CUSTODY_TREASURY_KEYPAIR=/etc/lichen/custody-treasury-mainnet.json

# Source-chain RPC routes. Keep a route unset until it is intentionally live.
# CUSTODY_SOLANA_RPC_URL=REPLACE_WITH_SOLANA_RPC_URL
# CUSTODY_ETH_RPC_URL=REPLACE_WITH_ETHEREUM_RPC_URL
# CUSTODY_BNB_RPC_URL=REPLACE_WITH_BSC_RPC_URL
# CUSTODY_EVM_RPC_URL=REPLACE_WITH_LEGACY_ETHEREUM_RPC_URL
# CUSTODY_NEOX_RPC_URL=REPLACE_WITH_NEO_X_RPC_URL
# CUSTODY_NEOX_CHAIN_ID=REPLACE_WITH_NEO_X_CHAIN_ID
# CUSTODY_SOLANA_CONFIRMATIONS=32
# CUSTODY_EVM_CONFIRMATIONS=12
# CUSTODY_NEOX_CONFIRMATIONS=12

# Source-chain treasury addresses and fee-payer controls.
# CUSTODY_TREASURY_SOLANA=REPLACE_WITH_SOLANA_TREASURY_ADDRESS
# CUSTODY_TREASURY_ETH=REPLACE_WITH_ETHEREUM_TREASURY_ADDRESS
# CUSTODY_TREASURY_BNB=REPLACE_WITH_BSC_TREASURY_ADDRESS
# CUSTODY_TREASURY_EVM=REPLACE_WITH_LEGACY_EVM_TREASURY_ADDRESS
# CUSTODY_TREASURY_NEOX=REPLACE_WITH_NEO_X_TREASURY_ADDRESS
# CUSTODY_SOLANA_FEE_PAYER=/etc/lichen/secrets/solana-fee-payer-mainnet.json
# CUSTODY_SOLANA_TREASURY_OWNER=REPLACE_WITH_SOLANA_TREASURY_OWNER

# Explicit stablecoin source contracts or mints. Do not rely on generic EVM
# aliases for BSC or Ethereum after route hardening.
# CUSTODY_SOLANA_USDC_MINT=REPLACE_WITH_SOLANA_USDC_MINT
# CUSTODY_SOLANA_USDT_MINT=REPLACE_WITH_SOLANA_USDT_MINT
# CUSTODY_ETH_USDC_TOKEN_ADDR=REPLACE_WITH_ETHEREUM_USDC_CONTRACT
# CUSTODY_ETH_USDT_TOKEN_ADDR=REPLACE_WITH_ETHEREUM_USDT_CONTRACT
# CUSTODY_BSC_USDC_TOKEN_ADDR=REPLACE_WITH_BSC_USDC_CONTRACT
# CUSTODY_BSC_USDT_TOKEN_ADDR=REPLACE_WITH_BSC_USDT_CONTRACT

# Wrapped Lichen contract addresses from the active symbol registry.
# CUSTODY_LUSD_TOKEN_ADDR=REPLACE_WITH_LUSD_CONTRACT
# CUSTODY_WSOL_TOKEN_ADDR=REPLACE_WITH_WSOL_CONTRACT
# CUSTODY_WETH_TOKEN_ADDR=REPLACE_WITH_WETH_CONTRACT
# CUSTODY_WBNB_TOKEN_ADDR=REPLACE_WITH_WBNB_CONTRACT
# CUSTODY_WGAS_TOKEN_ADDR=REPLACE_WITH_WGAS_CONTRACT
# CUSTODY_WNEO_TOKEN_ADDR=REPLACE_WITH_WNEO_CONTRACT
# CUSTODY_NEOX_NEO_TOKEN_ADDR=REPLACE_WITH_NEO_X_NEO_CONTRACT

# Rebalance and swap execution controls.
# CUSTODY_REBALANCE_THRESHOLD_BPS=500
# CUSTODY_REBALANCE_TARGET_BPS=5000
# CUSTODY_REBALANCE_MAX_SLIPPAGE_BPS=100
# CUSTODY_JUPITER_API_URL=REPLACE_WITH_JUPITER_API_URL
# CUSTODY_UNISWAP_ROUTER=REPLACE_WITH_UNISWAP_ROUTER

# Threshold signer, webhook, and withdrawal controls.
# CUSTODY_SIGNER_ENDPOINTS=http://127.0.0.1:9201
# CUSTODY_SIGNER_THRESHOLD=1
# CUSTODY_SIGNER_PQ_ADDRESSES=REPLACE_WITH_COMMA_SEPARATED_SIGNER_ADDRESSES
# CUSTODY_SIGNER_AUTH_TOKENS=REPLACE_WITH_COMMA_SEPARATED_SIGNER_TOKENS
# CUSTODY_WEBHOOK_ALLOWED_HOSTS=REPLACE_WITH_COMMA_SEPARATED_PUBLIC_HOSTS
# CUSTODY_WEBHOOK_MAX_INFLIGHT=64
# CUSTODY_WITHDRAWAL_PENDING_BURN_TTL_SECS=3600
# CUSTODY_EVM_MULTISIG_ADDRESS=REPLACE_WITH_ETHEREUM_MULTISIG
# CUSTODY_NEOX_MULTISIG_ADDRESS=REPLACE_WITH_NEO_X_MULTISIG
# CUSTODY_OPERATOR_CONFIRMATION_TOKENS=REPLACE_WITH_COMMA_SEPARATED_OPERATOR_TOKENS
# CUSTODY_WITHDRAWAL_ELEVATED_DELAY_SECS=3600
# CUSTODY_WITHDRAWAL_EXTRAORDINARY_DELAY_SECS=86400

# Local development only. Leave unset in production.
# CUSTODY_ALLOW_INSECURE_SEED=1
# CUSTODY_ALLOW_LOCAL_WEBHOOKS=1
# CUSTODY_WS_EVENTS_ALLOW_QUERY_TOKEN=1
# LICHEN_LOCAL_DEV=1
# DEV_CORS=1
