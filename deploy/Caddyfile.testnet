faucet.lichen.network {
    tls internal
    import common_headers

    @api path /faucet/*
    handle @api {
        reverse_proxy 127.0.0.1:9100
    }

    @health path /health
    handle @health {
        reverse_proxy 127.0.0.1:9100
    }

    handle {
        respond "faucet API endpoint not found" 404
    }
}
