# Lichen validator mainnet environment example.
# Mirrors /etc/lichen/env-mainnet as generated by deploy/setup.sh.
# Install filled production files as root-owned 0600 files. Do not commit filled
# copies or live secrets.

LICHEN_NETWORK=mainnet
LICHEN_RPC_PORT=9899
LICHEN_WS_PORT=9900
LICHEN_P2P_PORT=8001
LICHEN_EXTERNAL_ADDR=REPLACE_WITH_PUBLIC_HOSTNAME_OR_IP:8001
LICHEN_KEYPAIR_PASSWORD=REPLACE_WITH_KEYPAIR_PASSWORD
LICHEN_SIGNER_BIND=127.0.0.1:9201
LICHEN_SIGNER_AUTH_TOKEN=REPLACE_WITH_64_HEX_SIGNER_TOKEN
LICHEN_CONTRACTS_DIR=/var/lib/lichen/contracts
RUST_LOG=info
LICHEN_INCIDENT_STATUS_FILE=/etc/lichen/incident-status-mainnet.json
LICHEN_SIGNED_METADATA_MANIFEST_FILE=/etc/lichen/signed-metadata-manifest-mainnet.json
LICHEN_SERVICE_FLEET_CONFIG_FILE=/etc/lichen/service-fleet-mainnet.json
LICHEN_SERVICE_FLEET_UPSTREAM_RPC_URL=
LICHEN_SERVICE_FLEET_STATUS_FILE=/var/lib/lichen/service-fleet-status-mainnet.json
LICHEN_EXTRA_ARGS=--auto-update=off

# Required when this validator exposes public bridge intake through RPC.
CUSTODY_URL=http://127.0.0.1:9106
CUSTODY_API_AUTH_TOKEN=REPLACE_WITH_64_HEX_CUSTODY_API_TOKEN

# Operator-only controls. Enable only through the host secret manager.
# LICHEN_ADMIN_TOKEN=REPLACE_WITH_OPERATOR_ADMIN_TOKEN

# Oracle price-feed overrides for hosts that cannot reach the default upstream.
# LICHEN_ORACLE_WS_URL=wss://stream.binance.us:9443/ws/solusdt@aggTrade/ethusdt@aggTrade/bnbusdt@aggTrade
# LICHEN_ORACLE_REST_URL=https://api.binance.us/api/v3/ticker/price?symbols=["SOLUSDT","ETHUSDT","BNBUSDT"]
# LICHEN_DISABLE_ORACLE=1
